---
// components
import Layout from '../layouts/Layout.astro';
import WallpapersGrid from '../components/wallpapers/WallpapersGrid.astro';
import WallpapersGridItem from '../components/wallpapers/WallpapersGridItem.astro';

const aspectRatioDownloads = (
  basePath: string,
  filePrefix: string,
  excludeFormats: string[] = [],
) => [
  { label: '16:9', href: `${basePath}/${filePrefix}-16-9.png` },
  { label: '4:3', href: `${basePath}/${filePrefix}-4-3.png` },
  { label: '3:4', href: `${basePath}/${filePrefix}-3-4.png` },
  { label: '20:9', href: `${basePath}/${filePrefix}-20-9.png` },
  { label: '1:1', href: `${basePath}/${filePrefix}-1-1.png` },
].filter(({ label }) => !excludeFormats.includes(label));

const gridWallpaper = ({
  title,
  image,
  packageHref,
  basePath,
  filePrefix,
  excludeFormats = [],
  new: isNew = false,
}: {
  title: string;
  image: string;
  packageHref: string;
  basePath: string;
  filePrefix: string;
  excludeFormats?: string[];
  new?: boolean;
}) => ({
  title,
  image,
  packageHref,
  new: isNew,
  downloads: aspectRatioDownloads(basePath, filePrefix, excludeFormats),
});

const gridWallpapers = [
  gridWallpaper({
    title: 'Cyberpunks.shop hardware',
    image: '/wallpapers/previews/cyberpunks-shop-hardware.webp',
    packageHref: '/wallpapers/cyberpunks-shop-hardware/robonomics.network-cyberpunks-shop-hardware-wallpapers.zip',
    basePath: '/wallpapers/cyberpunks-shop-hardware',
    filePrefix: 'robonomics.network-cyberpunks-shop-hardware',
    new: true,
  }),
  gridWallpaper({
    title: 'Privacy first',
    image: '/wallpapers/previews/privacy-first.webp',
    packageHref: '/wallpapers/privacy-first/robonomics.network-privacy-first-wallpapers.zip',
    basePath: '/wallpapers/privacy-first',
    filePrefix: 'robonomics.network-privacy-first',
    new: true,
  }),
  gridWallpaper({
    title: 'Digital freedom',
    image: '/wallpapers/previews/digital-freedom.webp',
    packageHref: '/wallpapers/digital-freedom/robonomics.network-digital-freedom-wallpapers.zip',
    basePath: '/wallpapers/digital-freedom',
    filePrefix: 'robonomics.network-digital-freedom',
  }),
  gridWallpaper({
    title: 'Altruist air',
    image: '/wallpapers/previews/altruist-air.webp',
    packageHref: '/wallpapers/altruist-air/robonomics.network-altruist-air.zip',
    basePath: '/wallpapers/altruist-air',
    filePrefix: 'robonomics.network-altruist-air',
  }),
  gridWallpaper({
    title: 'Aira is back',
    image: '/wallpapers/previews/aira-is-back.webp',
    packageHref: '/wallpapers/aira-is-back/robonomics.network-aira-is-back.zip',
    basePath: '/wallpapers/aira-is-back',
    filePrefix: 'robonomics.network-aira-is-back',
  }),
  gridWallpaper({
    title: 'Devcon 2024 Space Monkey',
    image: '/wallpapers/previews/space-monkey.webp',
    packageHref: '/wallpapers/space-monkey/robonomics.network-space-monkey.zip',
    basePath: '/wallpapers/space-monkey',
    filePrefix: 'robonomics.network-space-monkey',
  }),
  gridWallpaper({
    title: 'Space cat and Robot',
    image: '/wallpapers/previews/space-cat-and-robot.webp',
    packageHref: '/wallpapers/space-monkey/robonomics.network-space-monkey.zip',
    basePath: '/wallpapers/space-monkey',
    filePrefix: 'robonomics.network-space-monkey',
  }),
  gridWallpaper({
    title: 'Space Shiva',
    image: '/wallpapers/previews/space-shiva.webp',
    packageHref: '/wallpapers/space-shiva/robonomics.network-space-shiva.zip',
    basePath: '/wallpapers/space-shiva',
    filePrefix: 'robonomics.network-space-shiva',
  }),
  gridWallpaper({
    title: 'Electric Sheep',
    image: '/wallpapers/previews/electric-sheep.webp',
    packageHref: '/wallpapers/electric-sheep/robonomics.network-electric-sheep.zip',
    basePath: '/wallpapers/electric-sheep',
    filePrefix: 'robonomics.network-electric-sheep',
    excludeFormats: ['20:9'],
  }),
  gridWallpaper({
    title: 'Space travelers',
    image: '/wallpapers/previews/space-travelers.webp',
    packageHref: '/wallpapers/space-travelers/robonomics.network-space-travelers.zip',
    basePath: '/wallpapers/space-travelers',
    filePrefix: 'robonomics.network-space-travelers',
  }),
  gridWallpaper({
    title: 'Astronaut coloured',
    image: '/wallpapers/previews/astronaut-coloured.webp',
    packageHref: '/wallpapers/astronaut-coloured/robonomics.network-astronaut-coloured.zip',
    basePath: '/wallpapers/astronaut-coloured',
    filePrefix: 'robonomics.network-astronaut-coloured',
  }),
  gridWallpaper({
    title: 'Astronaut black and white',
    image: '/wallpapers/previews/astronaut-bw.webp',
    packageHref: '/wallpapers/astronaut-bw/robonomics.network-astronaut-bw.zip',
    basePath: '/wallpapers/astronaut-bw',
    filePrefix: 'robonomics.network-astronaut-bw',
  }),
];
---


<Layout 
	title={$tr("Robonomics Wallpapers")}
	description={$tr("We created beautiful Robonomics themed wallpapers for different devices that you can use!")}
  pageTitle={$tr("wallpapers")}
	ogImage="/website_cover_wallpapers.webp"
>

  <section class="layout layout__content highlight text-center">
    <p>We are passionate about what we do, so of course we can’t resist creating artistic wallpapers inspired by the Robonomics universe — robotics, cyberpunk aesthetics, digital freedom, and even space (no, we don’t have our own spaceship yet).</p>
    <p>Download them for free and enjoy.</p>
  </section>

  <WallpapersGrid>
    {gridWallpapers.map((item) => (
      <WallpapersGridItem {...item} />
    ))}
  </WallpapersGrid>

  <section class="hidden-wallpapers section">
    <div class="layout layout__content">
      <div class="highlight-solid-green__wrapper">
        <h2 class="highlight-solid-green">{$tr('Hide your folder with secret wallpaper')}</h2>
      </div>
      <img src="/wallpapers/previews/bw_astronaut_artboard_1.webp" alt="black and white astronaut wallpaper"/>
      <p>{$tr("We've created secret wallpapers just for you! Download the background and folder icons, and your folders will blend seamlessly into your Home Screen—leaving only beautiful artwork visible.")}</p>
      <div class="wallpapers__links">
        <a aria-label="download hidden wallpaper for desktop" class="wallpapers-link-desktop" href="/wallpapers/hidden/robonomics.network-robonomics-secret-wallpapers.jpg" download>{$tr('Desktop background')}</a>
        <a aria-label="download hidden wallpaper icons for Mac OS" class="hidden-wallpaper-mac" href="/wallpapers/hidden/robonomics.network-robonomics-secret-wallpapers-icons-os.zip" download>{$tr('Mac OS icons')}</a>
        <a aria-label="download hidden wallpaper icons for Windows" class="hidden-wallpaper-windows" href="/wallpapers/hidden/robonomics.network-robonomics-secret-wallpapers-icons-windows.zip" download>{$tr('Windows icons')}</a>
      </div>
    </div>
  </section>
</Layout>


<style is:global>

  .wallpapers__links {
      display: flex;
      align-items: center;
      gap: calc(var(--space) * 0.5);
      margin-bottom: var(--space);
    }
  
    .wallpapers__links a {
      line-height: 1;
      font-size: calc(var(--base-font-size) * 0.9);
      font-variation-settings: var(--font-flex-bold);
      color: var(--color-dark);
      text-decoration: underline;
      background-position: left;
      background-repeat: no-repeat;
      cursor: pointer;
    }
  
    .wallpapers__links a:hover {
      color: var(--color-link);
    }
  
    .wallpapers-link-desktop {
      padding-left: 42px;
      background-image: url("data:image/svg+xml,%3Csvg width='31' height='23' viewBox='0 0 31 23' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M29.9465 0H1.05346C0.47166 0 0 0.47166 0 1.05345V16.7576C0 17.3394 0.47166 17.811 1.05346 17.811H29.9465C30.5283 17.811 31 17.3394 31 16.7576V1.05345C31 0.47166 30.5283 0 29.9465 0Z' fill='black'/%3E%3Cpath d='M21.5198 21.0512H17.9434V19.6386H13.0567V21.0512H9.48024C8.97558 21.0512 8.56641 21.4603 8.56641 21.9651C8.56641 22.4697 8.97552 22.8789 9.48024 22.8789H21.5198C22.0245 22.8789 22.4336 22.4698 22.4336 21.9651C22.4336 21.4604 22.0245 21.0512 21.5198 21.0512Z' fill='black'/%3E%3C/svg%3E%0A");
      background-size: 30px 22px;
    }
  
  </style>
  
  <style>



    h2.highlight-solid-green {
      display: inline;
      font-size: calc(var(--base-font-size)* 1.25);
      font-variation-settings: var(--font-flex-extrabold);
      padding: 0.4rem 0.8rem;
      text-align: left;
    }
  
    .highlight-solid-green__wrapper {
      margin-bottom: var(--space-text);
    }
  
    .wallpapers__links-wrapper {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: calc(var(--space) * 0.5);
    }
  
    .wallpapers__links img {
      min-width: 31px;
    }
  
    .hidden-wallpapers img {
      margin-bottom: var(--space);
    }
  
  
    .hidden-wallpapers a {
      min-height: 32px;
      padding-top: 6px;
    }
  
    .hidden-wallpapers .wallpapers__links {
      display: flex;
      flex-wrap: wrap;
      gap: calc(var(--space) * 1.5);
    }
  
    .hidden-wallpaper-mac {
      padding-left: 42px;
      background-image: url("data:image/svg+xml,%3Csvg width='24' height='30' viewBox='0 0 24 30' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M17.6645 0C17.733 0 17.8015 0 17.8739 0C18.042 2.07605 17.2496 3.62728 16.2865 4.75062C15.3416 5.86621 14.0476 6.94818 11.9547 6.78401C11.8151 4.73769 12.6088 3.30152 13.5706 2.18076C14.4625 1.13627 16.0978 0.20683 17.6645 0Z' fill='black'/%3E%3Cpath d='M24 21.6086C24 21.6293 24 21.6474 24 21.6668C23.4118 23.4481 22.5729 24.9748 21.5491 26.3916C20.6145 27.6778 19.4691 29.4087 17.4241 29.4087C15.657 29.4087 14.4832 28.2724 12.6722 28.2414C10.7564 28.2104 9.7029 29.1915 7.95131 29.4384C7.75094 29.4384 7.55058 29.4384 7.35409 29.4384C6.06787 29.2523 5.02984 28.2336 4.27362 27.3158C2.04374 24.6038 0.320586 21.1006 0 16.6176C0 16.1781 0 15.7398 0 15.3003C0.135732 12.0919 1.69471 9.48324 3.76689 8.21899C4.8605 7.5468 6.36389 6.97414 8.03792 7.23009C8.75536 7.34126 9.48831 7.58687 10.1308 7.82989C10.7396 8.06387 11.501 8.47882 12.2223 8.45685C12.711 8.44263 13.197 8.18797 13.6895 8.00828C15.1322 7.48733 16.5464 6.89011 18.4104 7.17062C20.6507 7.50931 22.2407 8.50468 23.2231 10.0404C21.328 11.2465 19.8298 13.064 20.0857 16.1677C20.3133 18.9871 21.9524 20.6365 24 21.6086Z' fill='black'/%3E%3C/svg%3E%0A");
      background-size: 25px 30px;
    }
  
    .hidden-wallpaper-windows {
      padding-top: 9px;
      padding-left: 42px;
      background-image: url("data:image/svg+xml,%3Csvg width='26' height='28' viewBox='0 0 26 28' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8.87475 3.28266L0 5.05333V13.2454L8.87469 13.096L8.87475 3.28266ZM25.3188 15.18L10.9054 14.9333V25.1213L25.3188 28V15.18ZM8.87475 14.9027L6.18961e-05 14.752V22.9427L8.87475 24.7147V14.9027ZM25.3188 0L10.9054 2.876V13.064L25.3188 12.8187V0Z' fill='%23010002'/%3E%3C/svg%3E%0A");
      background-size: 25px 28px;
    }
  
    @media screen and (max-width: 450px) {
  
      h2.highlight-solid-green {
        padding: 0rem 0.2rem;
      }
  
      .wallpapers__links {
        gap: var(--space);
      }
  
      .wallpapers__links img {
        min-width: unset;
        width: 20px;
      }
      
    }
  </style>