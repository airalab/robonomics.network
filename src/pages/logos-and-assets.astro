---
import Layout from '../layouts/Layout.astro';
import DownloadItem from '../components/DownloadItem.astro';

const logosIntroText = `
  <p>${await $tr('We’ve prepared Robonomics and XRT logos, recommended colors, and typography for the community. Feel free to download and use them.')}</p>
`;

const logoAsset = (slug: string, title: string) => {
  const base = `/pages/logos-and-assets/${slug}`;
  const zip = `${base}/${slug}.zip`;

  return {
    title,
    image: `${base}/${slug}.webp`,
    downloadChunks: {
      png: `${base}/${slug}.png`,
      svg: `${base}/${slug}.svg`,
      webp: `${base}/${slug}.webp`,
      zip,
    },
    download: zip,
  };
};

const logos = [
	logoAsset('robonomics-network-logo-sign-black', 'Robonomics Network logo sign (black)'),
	logoAsset('robonomics-network-logo-sign-white', 'Robonomics Network logo sign (white)'),
	logoAsset('robonomics-network-logo-title-black', 'Robonomics Network logo title (black)'),
	logoAsset('robonomics-network-logo-title-white', 'Robonomics Network logo title (white)'),
	logoAsset('robonomics-network-logo-title-line-black', 'Robonomics Network logo title line (black)'),
	logoAsset('robonomics-network-logo-title-line-white', 'Robonomics Network logo title line (white)'),
	logoAsset('robonomics-network-logo-xrt-black', 'Robonomics Network logo XRT (black)'),
	logoAsset('robonomics-network-logo-xrt-white', 'Robonomics Network logo XRT (white)'),
	logoAsset('robonomics-network-logo-xrt-line-black', 'Robonomics Network logo XRT Line (black)'),
	logoAsset('robonomics-network-logo-xrt-line-white', 'Robonomics Network logo XRT line (white)')
];
---

<Layout 
	title={$tr("Robonomics Logos and Assets")}
	description={$tr("We have put together Robonomics logos, colors, assets and guidelines to show how you may use it.")}
	ogImage="/opengraph/logo-and-assets.webp"
	pageTitle={$tr("Logo and assets")}
  pageIntroText={logosIntroText}
>

	<section class="layout">
		<h2>Robonomics & XRT {$tr('logo')} 2026</h2>
	</section>

	<section class="section layout layout__wide grid-2">
		{logos.map((item) => (
			<DownloadItem
				framed
				title={item.title}
				image={item.image}
				previewHref={item.download}
				previewDownload={true}
				previewAriaLabel={`download ${item.title}`}
				downloadChunks={item.downloadChunks}
			/>
		))}
	</section>

</Layout>