---
export interface WallpaperDownload {
  label: string;
  href: string;
}

interface Props {
  title: string;
  image: string;
  packageHref: string;
  downloads: WallpaperDownload[];
  new?: boolean;
}

const { title, image, packageHref, downloads, new: isNew = false } = Astro.props;
const titleLabel = await $tr(title);
const newLabel = await $tr('New');
const downloadAriaLabel = `download Robonomics wallpaper for desktop - ${title}`;
const imageAriaLabel = `Robonomics wallpaper for desktop - ${title}`;
---

<article class="wallpapers-grid__item">
  <div class="wallpapers-grid__media">
    <a aria-label={downloadAriaLabel} href={packageHref} download>
      <img src={image} aria-label={imageAriaLabel} alt="" />
    </a>
    {isNew && <span class="wallpapers-grid__badge">{newLabel}</span>}
  </div>
  <h5>{titleLabel}</h5>
  <div class="wallpaper-download">
    {downloads.map(({ label, href }) => (
      <a aria-label={downloadAriaLabel} href={href} download class="oldy oldy__link">
        {label}
      </a>
    ))}
  </div>
</article>

<style>
  .wallpapers-grid__item {
    --row-span: 3;
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span var(--row-span, 3);
    gap: 0.5rem;
  }

  .wallpapers-grid__media {
    position: relative;
  }

  .wallpapers-grid__media > a {
    display: block;
    overflow: hidden;
  }

  .wallpapers-grid__badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.15rem 0.5rem;
    font-size: calc(var(--base-font-size) * 0.7);
    font-weight: bold;
    line-height: 1.2;
    color: var(--color-dark);
    background-color: var(--rb-color-green-accent);
  }

  .wallpapers-grid__item img {
    width: 100%;
    height: auto;
    display: block;
  }

  .wallpaper-download {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .wallpaper-download .oldy {
    --oldy-box-size: .1rem;
    --oldy-color: var(--color-dark);
  }

  .wallpaper-download a {
    padding: 0.2rem 1rem;
    font-size: calc(var(--base-font-size) * 0.8);
    font-weight: bold;
  }
</style>
