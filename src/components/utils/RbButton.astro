---

const {
  anchor = false,
  block = false,
  buttonstyle = '3d',
  buttoncolor = 'blue',
  type = 'primary',
  link,
  scale = '1',
  disabled = false,
  loading = false,
  extraCls = '',
  radius = false,
  noTarget =  false,
  ...attrs
} = Astro.props;

// Generate the CSS classes based on the props
const classes = [
  'rb-button',
  'button',
  loading && 'rb-button-loading',
  block && 'rb-button-block',
  buttonstyle && `rb-button-${buttonstyle}`,
  buttoncolor && `rb-button-${buttoncolor}`,
  type && `rb-button-${type}`,
  radius && `rb-button-radius`,
  extraCls
].filter(Boolean).join(' ');

// Determine the component type
const componentType = attrs.href || link ? 'a' : 'button';

// Define the smooth scroll directive replacement
const smoothScroll = anchor ? { updateHistory: false, offset: -250 } : null;
---

{componentType === 'a' ? (
  <a
    {...attrs}
    class={classes}
    style={`transform: scale(${scale});`}
    smooth-scroll={JSON.stringify(smoothScroll)}
    onclick={attrs.onClick}
    target={!noTarget ? "_blank" : "_self"} 
    aria-busy={loading ? 'true' : undefined}
    aria-disabled={disabled || loading ? 'true' : undefined}
  >
    {loading && <span class="rb-button__spinner" aria-hidden="true" />}
    <slot />
  </a>
) : (
  <button
    {...attrs}
    class={classes}
    style={`transform: scale(${scale});`}
    smooth-scroll={JSON.stringify(smoothScroll)}
    onclick={attrs.onClick}
    disabled={disabled || loading}
    aria-busy={loading ? 'true' : undefined}
  >
    {loading && <span class="rb-button__spinner" aria-hidden="true" />}
    <slot />
  </button>
)}

<style is:global>
  .rb-button {
    --b-color-background: var(--color-blue);
    --b-color-text: var(--color-light);
    --b-color-shadow: var(--color-dark);
    --b-color-borderwidth: 1px;
    --b-color-padding: 1rem;
    --b-color-hover: var(--color-light);

    align-content: center;
    appearance: none;
    background-color: var(--b-color-background);
    border-color: var(--b-color-background);
    border-style: solid;
    border-width: var(--b-color-borderwidth);
    color: var(--b-color-text);
    cursor: pointer;
    display: inline-flex;
    font-family: var(--font-family);
    font-size: var(--base-font-size);
    font-variation-settings: var(--font-flex-bold);
    font-weight: 500;
    gap: var(--b-color-padding);
    justify-content: center;
    line-height: 1;
    padding: var(--b-color-padding);
    position: relative;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color 0.3s ease-in-out, border 0.3s ease-in-out,
      color 0.3s ease-in-out;
  }

  a.rb-button,
  button.rb-button {
    color: var(--b-color-text);
  }

  .rb-button:hover,
  a.rb-button:hover,
  button.rb-button:hover {
    background-color: color-mix(in srgb, var(--b-color-background) 85%, black);
    border-color: color-mix(in srgb, var(--b-color-background) 85%, black);
    color: var(--b-color-hover);
  }

  .rb-button-3d {
    box-shadow: 4px 4px 0 var(--b-color-shadow);
  }

  .rb-button[disabled] {
    pointer-events: none;
    filter: grayscale(1);
    --b-color-background: var(--color-gray);
  }

  .rb-button-loading {
    pointer-events: none;
  }

  .rb-button__spinner {
    width: 1em;
    height: 1em;
    border: 2px solid color-mix(in srgb, var(--b-color-text) 35%, transparent);
    border-top-color: var(--b-color-text);
    border-radius: 50%;
    display: inline-block;
    animation: rb-button-spin 0.8s linear infinite;
  }

  @keyframes rb-button-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .rb-button-block {
    display: block;
    width: 100%;
  }

  .rb-button-radius {
    border-radius: 6px;
  }

  .rb-button-ok {
    --b-color-background: var(--color-green);
    cursor: default;
    pointer-events: none;
  }

  .rb-button-error {
    --b-color-background: var(--color-red);
    cursor: default;
    pointer-events: none;
  }

  .rb-button-na {
    --b-color-background: var(--color-gray);
    cursor: default;
    pointer-events: none;
  }
</style>