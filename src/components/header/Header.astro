---
import { getLocale } from "astro-i18n-aut";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const locale = getLocale(Astro.url) || "en";

const normalizePath = (path) => {
  if (!path) return "/";

  let value = path.length > 1 ? path.replace(/\/+$/, "") : path;

  if (locale !== "en" && value.startsWith(`/${locale}`)) {
    value = value.slice(locale.length + 1) || "/";
  } else if (value.startsWith("/en/")) {
    value = value.slice(3) || "/";
  } else if (value === "/en") {
    value = "/";
  }

  return value || "/";
};

const currentPath = normalizePath(Astro.url.pathname);
const isActive = (target) => currentPath === normalizePath(target);
---

<header>
  <div class="layout">
    <section class="logo">
      <a href="/" class="header-logo"><img alt="Robonomics website logo" src="/images/robonomics-logo-sign.svg" /></a>
    </section>

    <section class="nav">
      <a href="/ecosystem/" class:list={[isActive('/ecosystem') && 'is-active']}>{$tr('Ecosystem')}</a>
      <a href="/" class:list={[isActive('/') && 'is-active']}>{$tr('Home')}</a>
      <a href="/contact/" class:list={[isActive('/contact') && 'is-active']}>{$tr('Ask a technician')}</a>
    </section>

    <section class="lang">
      <LanguageSwitcher />
    </section>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('header');
    
    // logos and assets redirect on logo right click
    const headerLogo = document.querySelector('.header-logo');
    if (headerLogo) {
      headerLogo.addEventListener('contextmenu', (event) => {
        event.preventDefault(); 
        window.location.href = '/logos-and-assets/'; 
      });
    }
    let hasScrolled = false;
    
    const handleScroll = () => {
      const currentScroll = window.scrollY;
      if (!hasScrolled && currentScroll > 50) {
        header?.classList.add('is-scrolled');
        hasScrolled = true;
      } else if (hasScrolled && currentScroll <= 50) {
        header?.classList.remove('is-scrolled');
        hasScrolled = false;
      }
    };
    
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); 
  });
</script>

<style>

  .layout {
    position: relative;
  }

  .lang {
    position: absolute;
    right: var(--space);
    bottom: 0;
  }

  section {
    text-transform: uppercase;
    font-weight: 900;
    font-size: calc(var(--base-font-size) * 0.7);
    padding-top: calc(var(--space) * 0.5);
    gap: calc(var(--space) * 0.5);
    transition: all 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
  }

  .header-logo {
    display: block;
    width: 70px;
    transition: width 0.5s cubic-bezier(0.075, 0.82, 0.165, 1);
  }

  .header-logo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .logo {
    display: flex;
    justify-content: center;
  }

  .nav {
    display: grid;
    width: fit-content;
    margin: 0 auto;
    grid-template-columns: repeat(3, 1fr);
    text-align: center;
  }

  .nav a:first-child {
    text-align: right;
  }

  .nav a:last-child {
    color: var(--color-red);
  }

  .nav a.is-active {
    color: var(--color-dark);
    pointer-events: none;
    cursor: default;
  }

  .lang {
    display: flex;
    justify-content: center;
  }

  header.is-scrolled {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background-color: var(--color-light);
    border-bottom: 2px solid var(--color-dark);
    padding-bottom: calc(var(--space) * 0.5);
  }

  header.is-scrolled .header-logo {
    width: 40px;
  }

  header.is-scrolled section {
    font-size: calc(var(--base-font-size) * 0.6);
  }

  @media screen and (width < 580px) {
    .lang {
      bottom: auto;
      top: calc(var(--space)*0.3);
    }
  }

  @media screen and (width < 400px) {
    section {
      font-size: calc(var(--base-font-size) * 0.6);
    }
  }

</style>